# Copy to `.env` for local dev. Never commit `.env`.

# Causeway dev server
CAUSEWAY_HOST=127.0.0.1
CAUSEWAY_PORT=8000

# Reference task adapter (Dramatiq) — local Redis broker
CAUSEWAY_REDIS_URL=redis://127.0.0.1:6379/0

# Reference vector / DB
CAUSEWAY_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/causeway
