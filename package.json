{
  "name": "causeway-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "A lean backend framework for type-safe Python APIs — file-based routing, typed config/DI, scoped providers, plugin registry, and background tasks. Generates typed TypeScript clients off your Python handler signatures.",
  "homepage": "https://github.com/tamimbinhakim/causeway#readme",
  "bugs": {
    "url": "https://github.com/tamimbinhakim/causeway/issues"
  },
  "license": "MIT",
  "author": "Tamim Bin Hakim (@tamimbinhakim)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/causeway.git"
  },
  "workspaces": [
    "packages/*",
    "examples/*/frontend"
  ],
  "scripts": {
    "build": "pnpm -r --filter=./packages/causeway-* run build",
    "test:js": "pnpm -r --filter=./packages/causeway-* run test",
    "typecheck:js": "pnpm -r --filter=./packages/causeway-* run typecheck",
    "lint": "pnpm lint:ts && pnpm lint:py && pnpm lint:docs",
    "lint:ts": "oxlint .",
    "lint:py": "uv run --directory packages/causeway ruff check .",
    "lint:docs": "prettier --check \"**/*.{md,json,yaml,yml}\"",
    "format": "pnpm format:ts && pnpm format:py && pnpm format:docs",
    "format:ts": "oxfmt --ignore-path .oxfmtignore .",
    "format:py": "uv run --directory packages/causeway ruff format .",
    "format:docs": "prettier --write \"**/*.{md,json,yaml,yml}\"",
    "format:check": "pnpm format:check:ts && pnpm format:check:py && pnpm format:check:docs",
    "format:check:ts": "oxfmt --ignore-path .oxfmtignore --check .",
    "format:check:py": "uv run --directory packages/causeway ruff format --check .",
    "format:check:docs": "prettier --check \"**/*.{md,json,yaml,yml}\"",
    "typecheck": "uv run --directory packages/causeway mypy src",
    "test": "uv run --directory packages/causeway pytest",
    "clean": "pnpm -r run clean && rimraf node_modules .turbo packages/*/dist packages/*/.venv",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt --ignore-path .oxfmtignore"
    ],
    "packages/causeway/**/*.py": [
      "uv run --directory packages/causeway ruff check --fix",
      "uv run --directory packages/causeway ruff format"
    ],
    "*.{md,json,yaml,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@11.0.9"
}
