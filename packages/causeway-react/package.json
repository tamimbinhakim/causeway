{
  "name": "@causewayjs/react",
  "version": "0.2.5-alpha.0",
  "description": "React hooks for the Causeway route-key client runtime.",
  "keywords": [
    "python",
    "react",
    "rpc",
    "sse",
    "streaming",
    "causeway"
  ],
  "homepage": "https://github.com/tamimbinhakim/causeway#readme",
  "bugs": {
    "url": "https://github.com/tamimbinhakim/causeway/issues"
  },
  "license": "MIT",
  "author": "Tamim Bin Hakim (@tamimbinhakim)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/causeway.git",
    "directory": "packages/causeway-react"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@causewayjs/client": "workspace:*",
    "happy-dom": "20.9.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tsup": "8.5.1",
    "vite": "8.0.12",
    "vitest": "4.1.6"
  },
  "peerDependencies": {
    "@causewayjs/client": ">=0.1.0-alpha.0 <0.2.0",
    "react": ">=18.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
