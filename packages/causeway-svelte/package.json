{
  "name": "@causewayjs/svelte",
  "version": "0.1.1-alpha.0",
  "description": "Svelte store bindings (query, mutation, subscription) for causeway-generated clients.",
  "keywords": [
    "python",
    "rpc",
    "sse",
    "streaming",
    "svelte",
    "causeway"
  ],
  "homepage": "https://github.com/tamimbinhakim/causeway#readme",
  "bugs": {
    "url": "https://github.com/tamimbinhakim/causeway/issues"
  },
  "license": "MIT",
  "author": "Tamim Bin Hakim (@tamimbinhakim)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/causeway.git",
    "directory": "packages/causeway-svelte"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@causewayjs/ts": "workspace:*",
    "svelte": "5.55.9",
    "tsup": "8.5.1",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  },
  "peerDependencies": {
    "@causewayjs/ts": "workspace:*",
    "svelte": ">=4.0.0 <6"
  },
  "engines": {
    "node": ">=20"
  }
}
