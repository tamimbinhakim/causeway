{
  "name": "@causewayjs/next",
  "version": "0.1.0-alpha.0",
  "description": "Next.js helpers for the Causeway route-key client runtime.",
  "keywords": [
    "nextjs",
    "react",
    "rpc",
    "causeway"
  ],
  "homepage": "https://github.com/tamimbinhakim/causeway#readme",
  "bugs": {
    "url": "https://github.com/tamimbinhakim/causeway/issues"
  },
  "license": "MIT",
  "author": "Tamim Bin Hakim (@tamimbinhakim)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/causeway.git",
    "directory": "packages/causeway-next"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@causewayjs/client": "workspace:*",
    "@causewayjs/react": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "react": "19.2.6",
    "tsup": "8.5.1",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=20"
  }
}
